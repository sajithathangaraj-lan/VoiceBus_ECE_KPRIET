<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark_navy"
    tools:context=".MainActivity">

    <!-- Scrollable Dashboard Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- App Logo / Title Banner -->
            <TextView
                android:id="@+id/app_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="@string/app_name"
                android:textColor="@color/gold_primary"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center_horizontal"
                android:contentDescription="Smart Bus Assistant Dashboard Active" />

            <!-- Card 1: Incoming Bus Info -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_bus_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:strokeColor="@color/border_contrast"
                app:strokeWidth="2dp"
                app:cardBackgroundColor="@color/surface_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_header"
                        android:textColor="@color/text_light_gray"
                        android:textSize="18sp"
                        android:textAllCaps="true"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>

                    <!-- Bus Number (Huge font for visual impairment) -->
                    <TextView
                        android:id="@+id/bus_num_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/bus_number"
                        android:textColor="@color/gold_primary"
                        android:textSize="48sp"
                        android:textStyle="bold"
                        android:contentDescription="Incoming Bus Number 102" />

                    <!-- Route details -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/bus_route_label"
                        android:textColor="@color/text_light_gray"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/bus_route_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/bus_route_value"
                        android:textColor="@color/text_white"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/border_contrast"
                        android:layout_marginVertical="16dp" />

                    <!-- Grid for ETA and Status -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:baselineAligned="false">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/bus_eta_label"
                                android:textColor="@color/text_light_gray"
                                android:textSize="14sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/bus_eta_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/bus_eta_value"
                                android:textColor="@color/gold_primary"
                                android:textSize="24sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/bus_status_label"
                                android:textColor="@color/text_light_gray"
                                android:textSize="14sp"
                                android:textStyle="bold"/>

                            <!-- Status Badge -->
                            <TextView
                                android:id="@+id/bus_status_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:background="@drawable/badge_background"
                                android:text="@string/bus_status_value"
                                android:textColor="@color/gold_primary"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 2: Upcoming Stops Timeline -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:strokeColor="@color/border_contrast"
                app:strokeWidth="2dp"
                app:cardBackgroundColor="@color/surface_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/timeline_header"
                        android:textColor="@color/gold_primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textAllCaps="true" />

                    <!-- Stop Items (Timeline layout) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="16dp">

                        <!-- Item 1 (Current Stop) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="●"
                                android:textColor="@color/gold_primary"
                                android:textSize="24sp"
                                android:layout_marginEnd="12dp" />

                            <TextView
                                android:id="@+id/stop_item_current"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/stop_current"
                                android:textColor="@color/text_gold"
                                android:textSize="18sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Item 2 (Next Stop) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="○"
                                android:textColor="@color/text_white"
                                android:textSize="20sp"
                                android:layout_marginEnd="14dp" />

                            <TextView
                                android:id="@+id/stop_item_next_1"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/stop_next_1"
                                android:textColor="@color/text_white"
                                android:textSize="18sp" />
                        </LinearLayout>

                        <!-- Item 3 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="○"
                                android:textColor="@color/text_light_gray"
                                android:textSize="20sp"
                                android:layout_marginEnd="14dp" />

                            <TextView
                                android:id="@+id/stop_item_next_2"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/stop_next_2"
                                android:textColor="@color/text_light_gray"
                                android:textSize="18sp" />
                        </LinearLayout>

                        <!-- Item 4 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="○"
                                android:textColor="@color/text_light_gray"
                                android:textSize="20sp"
                                android:layout_marginEnd="14dp" />

                            <TextView
                                android:id="@+id/stop_item_next_3"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/stop_next_3"
                                android:textColor="@color/text_light_gray"
                                android:textSize="18sp" />
                        </LinearLayout>

                        <!-- Item 5 (Destination) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="■"
                                android:textColor="@color/gold_primary"
                                android:textSize="20sp"
                                android:layout_marginEnd="14dp" />

                            <TextView
                                android:id="@+id/stop_item_destination"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/stop_destination"
                                android:textColor="@color/gold_primary"
                                android:textSize="18sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 3: Action Guidance -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/border_contrast"
                app:strokeWidth="2dp"
                app:cardBackgroundColor="@color/surface_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/guidance_title"
                        android:textColor="@color/gold_primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textAllCaps="true" />

                    <!-- Quick Guidance Rows -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/action_board_desc"
                        android:textColor="@color/green_board"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center_vertical"
                        android:drawableStart="@android:drawable/ic_input_add"
                        android:drawablePadding="12dp"
                        app:drawableTint="@color/green_board"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/action_skip_desc"
                        android:textColor="@color/red_skip"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center_vertical"
                        android:drawableStart="@android:drawable/ic_delete"
                        android:drawablePadding="12dp"
                        app:drawableTint="@color/red_skip"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Full-Screen Touch-to-Start Overlay (Visible by default) -->
    <FrameLayout
        android:id="@+id/welcome_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_dark_navy"
        android:clickable="true"
        android:focusable="true"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <!-- Banner Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/welcome_title"
                android:textColor="@color/gold_primary"
                android:textSize="36sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="48dp" />

            <!-- Help Icon / Indicator -->
            <TextView
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:background="@drawable/badge_background"
                android:gravity="center"
                android:text="👆"
                android:textSize="80sp"
                android:layout_marginBottom="48dp"
                android:contentDescription="Double tap icon" />

            <!-- Command Instruction -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/welcome_instruction"
                android:textColor="@color/text_white"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center"
                android:lineSpacingExtra="8dp" />

            <!-- Extra caption for TalkBack -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Tap anywhere to hear this guidance again."
                android:textColor="@color/text_light_gray"
                android:textSize="16sp"
                android:gravity="center" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
