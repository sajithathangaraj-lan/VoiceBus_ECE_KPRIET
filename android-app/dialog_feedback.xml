<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface_card"
    android:padding="28dp">

    <!-- Dialog Header Icon -->
    <TextView
        android:id="@+id/dialog_icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="🚨"
        android:textSize="48sp"
        android:layout_marginBottom="16dp"
        android:importantForAccessibility="no" />

    <!-- Dialog Title -->
    <TextView
        android:id="@+id/dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dialog_board_title"
        android:textColor="@color/gold_primary"
        android:textSize="26sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Dialog Body Message -->
    <TextView
        android:id="@+id/dialog_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dialog_board_msg"
        android:textColor="@color/text_white"
        android:textSize="18sp"
        android:gravity="center"
        android:lineSpacingExtra="6dp"
        android:layout_marginBottom="28dp" />

    <!-- Action Buttons Stack (Stacked vertically for large touch targets) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Confirm Button (Large, high-contrast) -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/dialog_btn_confirm"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/button_board_background"
            android:text="@string/dialog_board_confirm"
            android:textColor="@color/text_black"
            android:textSize="20sp"
            android:textStyle="bold"
            android:focusable="true"
            android:clickable="true"
            android:contentDescription="Double tap to confirm boarding bus" />

        <!-- Cancel / Dismiss Button (Large outline style) -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/dialog_btn_cancel"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:background="@drawable/button_cancel_background"
            android:text="@string/dialog_cancel"
            android:textColor="@color/red_skip"
            android:textSize="20sp"
            android:textStyle="bold"
            android:focusable="true"
            android:clickable="true"
            android:contentDescription="Long press to cancel action and return" />
    </LinearLayout>
</LinearLayout>
